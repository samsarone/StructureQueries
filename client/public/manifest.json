{
  "manifest_version": 3,
  "name": "Structure Queries",
  "version": "0.1.0",
  "description": "Chrome extension for the Structure Queries client.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Structure Queries",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "identity",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://structurequeries.samsar.one/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://structurequeries.samsar.one wss://structurequeries.samsar.one;"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "popup.css",
        "popup.js",
        "fonts/poppins-400-latin.woff2",
        "fonts/poppins-600-latin.woff2",
        "fonts/poppins-700-latin.woff2",
        "structured-queries-monogram.svg",
        "structured-queries-wordmark.svg"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}
